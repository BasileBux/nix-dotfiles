[
  // Correctly return focus to the editor after closing fast-fuzzy-finder with `escape`
  {
    "key": "escape",
    "command": "runCommands",
    "args": {
      "commands": [
        "workbench.action.closeActiveEditor",
        "workbench.action.focusActiveEditorGroup"
      ]
    },
    "when": "activeWebviewPanelId == 'fast-fuzzy-finder.search'"
  },
  // focus toggle on terminal pane
  {
    "key": "ctrl+shift+t",
    "command": "workbench.action.togglePanel"
  },
  // toggle sidebar and focus to it
  {
    "command": "runCommands",
    "key": "ctrl+alt+y",
    "args": {
      "commands": [
        "workbench.action.toggleSidebarVisibility",
        "workbench.files.action.focusFilesExplorer"
      ]
    },
    "when": "editorTextFocus"
  },
  {
    "command": "runCommands",
    "key": "ctrl+alt+y",
    "args": {
      "commands": [
        "workbench.action.toggleSidebarVisibility",
        "workbench.action.focusActiveEditorGroup"
      ]
    },
    "when": "!editorTextFocus"
  },
  // toggle extras (basically almost full ui)
  {
    "command": "runCommands",
    "key": "ctrl+alt+w",
    "args": {
      "commands": [
        "workbench.action.toggleActivityBarVisibility",
        "toggle.toggleCustomTitleBar"
      ]
    }
  },
  // toggle tabs
  {
    "command": "workbench.action.hideEditorTabs",
    "key": "ctrl+alt+x",
    "when": "editorTabsVisible"
  },
  {
    "command": "workbench.action.showMultipleEditorTabs",
    "key": "ctrl+alt+x",
    "when": "!editorTabsVisible"
  },
  // move lines up / down
  {
    "key": "alt+j",
    "command": "editor.action.moveLinesDownAction",
    "when": "editorTextFocus && !editorReadonly && vim.active"
  },
  {
    "key": "alt+k",
    "command": "editor.action.moveLinesUpAction",
    "when": "editorTextFocus && !editorReadonly && vim.active"
  }
]
